# vSPACE Configuration Template
# ==============================
# Copy this file to .env and fill in your actual values
# Run: cp .env.example .env
#
# For interactive setup, run: python wizard.py

# =============================================================================
# MICROSOFT ENTRA VERIFIED ID (F-104)
# Required for VC issuance and presentation
# =============================================================================

# Azure AD Tenant ID (GUID format)
# Found in: Azure Portal > Azure Active Directory > Overview
AZURE_ENTRA_TENANT_ID=

# Azure AD Application Client ID (GUID format)
# Created in: Azure Portal > Azure Active Directory > App registrations
AZURE_AD_APP_CLIENT_ID=

# Azure AD Application Client Secret
# Created in: Azure Portal > Azure Active Directory > App registrations > Certificates & secrets
AZURE_AD_APP_CLIENT_SECRET=

# Azure Subscription ID (for resource provisioning)
# Found in: Azure Portal > Subscriptions
AZURE_SUBSCRIPTION_ID=

# =============================================================================
# ENTRA VERIFIED ID ENDPOINTS (F-104)
# Do not modify unless using custom deployment
# =============================================================================

# Entra Verified ID Issuance Authority
# Format: https://<your-tenant>.verifiedid.did.msidentity.com
ENTRA_VC_ISSUANCE_AUTHORITY=https://verifiedid.did.msidentity.com/v1.0/verifiableCredentials/createIssuanceRequest

# Entra Verified ID Presentation Authority
# Format: https://<your-tenant>.verifiedid.did.msidentity.com
ENTRA_VC_PRESENTATION_AUTHORITY=https://verifiedid.did.msidentity.com/v1.0/verifiableCredentials/createPresentationRequest

# DID Document Location (must be publicly accessible)
# Host at: https://vspacevote.com/.well-known/did.json
VSPACE_DID_DOCUMENT_URL=https://vspacevote.com/.well-known/did.json

# =============================================================================
# AZURE OPENAI SERVICE (F-108)
# Required for NLWeb conversational interfaces
# =============================================================================

# Azure OpenAI Service Endpoint
# Format: https://<your-resource>.openai.azure.com
AZURE_OPENAI_ENDPOINT=

# Azure OpenAI API Key
# Found in: Azure Portal > Azure OpenAI > Keys and Endpoint
AZURE_OPENAI_API_KEY=

# Azure OpenAI Deployment Name
# Example: gpt-4, gpt-35-turbo
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4

# =============================================================================
# AZURE AI SEARCH (F-108)
# Required for NLWeb vector store indexing
# =============================================================================

# Azure AI Search Service Endpoint
# Format: https://<your-search-service>.search.windows.net
AZURE_AI_SEARCH_ENDPOINT=

# Azure AI Search API Key (Admin or Query Key)
# Found in: Azure Portal > Azure AI Search > Keys
AZURE_AI_SEARCH_API_KEY=

# Azure AI Search Index Name
# Example: election-records, credential-state
AZURE_AI_SEARCH_INDEX_NAME=vspace-election-index

# =============================================================================
# AZURE KEY VAULT
# Required for secure secret storage
# =============================================================================

# Azure Key Vault URI
# Format: https://<your-vault-name>.vault.azure.net/
AZURE_KEY_VAULT_URI=

# =============================================================================
# AZURE COSMOS DB (F-010, F-103, F-109)
# Required for election record persistence
# =============================================================================

# Azure Cosmos DB Connection String
# Found in: Azure Portal > Cosmos DB account > Connection String
AZURE_COSMOS_DB_CONNECTION_STRING=

# Cosmos DB Database Name
AZURE_COSMOS_DB_DATABASE_NAME=ElectionGuardDb

# =============================================================================
# AZURE APP SERVICE (F-105, F-106)
# Required for PWA hosting
# =============================================================================

# vSpaceVote.com App Service Name
AZURE_APP_SERVICE_VSPACEVOTE_NAME=

# vSpaceVote.com Resource Group
AZURE_APP_SERVICE_VSPACEVOTE_RESOURCE_GROUP=

# vSpaceWallet.com App Service Name
AZURE_APP_SERVICE_VSPACEWALLET_NAME=

# vSpaceWallet.com Resource Group
AZURE_APP_SERVICE_VSPACEWALLET_RESOURCE_GROUP=

# Azure Front Door Endpoint (for CDN and DDoS protection)
AZURE_FRONT_DOOR_ENDPOINT=

# =============================================================================
# VSPACE CRYPTOGRAPHIC CONFIGURATION
# Optional: Override defaults for testing
# =============================================================================

# SAAC Curve (P-256 or P-384)
VSPACE_SAAC_CURVE=P-256

# Multi-Holder BBS Threshold (e.g., 2 for 2-of-2)
VSPACE_MULTIHOLDER_THRESHOLD=2

# Multi-Holder BBS Total Shares (e.g., 2 for 2-of-2)
VSPACE_MULTIHOLDER_TOTAL=2

# Election ID (leave empty to auto-generate)
VSPACE_ELECTION_ID=

# =============================================================================
# LOGGING AND MONITORING
# Optional: Configure observability
# =============================================================================

# Application Insights Connection String
# Found in: Azure Portal > Application Insights > Connection String
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
VSPACE_LOG_LEVEL=INFO

# Enable Azure Monitor (true/false)
VSPACE_ENABLE_AZURE_MONITOR=false

# =============================================================================
# DEVELOPMENT MODE
# Set to true for local testing with mocked services
# =============================================================================

# Enable Dry-Run Mode (no actual API calls)
VSPACE_DRY_RUN=true

# Mock Entra VC Issuance (true/false)
VSPACE_MOCK_ENTRA=true

# Mock NLWeb Responses (true/false)
VSPACE_MOCK_NLWEB=true
